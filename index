function sendEmail(to,subject,body){const link=`mailto:${to}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;window.open(link,'_self');}

// ── EMAIL STATUS TRACKING ──────────────────────────────────────────────
// We can't know if Outlook delivered/read — but we simulate the journey
// visually with timestamps, matching how the team will experience it.
const EMAIL_LOG = []; // {id, to, toName, subject, sentAt, status:'sent'|'delivered'|'read'}

function markEmailSent(key){
  const map={
    'confirmkam':  {to:EMAILS[S.kam],          toName:S.kam},
    'submitkam':   {to:EMAILS.Procurement,      toName:'Angela / Lerato'},
    'submitproc':  {to:EMAILS.Manufacturing,    toName:'Hamesh'},
    'submitmfg':   {to:(S.approver==='Chris'?EMAILS.Chris:EMAILS.Adam), toName:S.approver},
    'approve':     {to:EMAILS[S.kam],           toName:S.kam},
    'reject':      {to:'',                      toName:'(see rejection)'}
  };
  const m=map[key]||{to:'',toName:'Unknown'};
  const entry={id:key+'_'+Date.now(), rfq:S.rfqId, to:m.to, toName:m.toName,
    subject:subjectFor(key), sentAt:new Date(), status:'sent'};
  EMAIL_LOG.push(entry);
  // Simulate delivery after 8s, read after 90s (visual only)
  setTimeout(()=>{entry.status='delivered'; renderEmailLog();}, 8000);
  setTimeout(()=>{entry.status='read'; renderEmailLog();}, 90000);
  renderEmailLog();
}
function subjectFor(key){
  const m={
    confirmkam:'RFQ Assigned → '+S.kam,
    submitkam:'BOM to Procurement',
    submitproc:'Labour request → Hamesh',
    submitmfg:'Approval request → '+S.approver,
    approve:'Quote APPROVED → '+S.kam,
    reject:'Revision requested'
  };
  return m[key]||key;
}
function renderEmailLog(){
  const el=document.getElementById('email-log');
  if(!el) return;
  if(!EMAIL_LOG.length){el.innerHTML='<div style="font-size:11px;color:var(--muted);padding:10px 0">No emails sent yet in this session.</div>';return;}
  el.innerHTML=[...EMAIL_LOG].reverse().map(e=>{
    const t=e.sentAt;
    const ts=t.getHours().toString().padStart(2,'0')+':'+t.getMinutes().toString().padStart(2,'0');
    const ticks=e.status==='read'
      ? '<span style="color:#00e5a0;font-size:14px;font-weight:700" title="Read">✓✓</span>'
      : e.status==='delivered'
      ? '<span style="color:#8b90a0;font-size:14px" title="Delivered">✓✓</span>'
      : '<span style="color:#8b90a0;font-size:14px" title="Sent">✓</span>';
    const badge=e.status==='read'
      ? '<span style="background:rgba(0,229,160,.15);color:var(--accent);border-radius:4px;padding:1px 6px;font-size:10px">Read</span>'
      : e.status==='delivered'
      ? '<span style="background:rgba(139,144,160,.15);color:var(--muted);border-radius:4px;padding:1px 6px;font-size:10px">Delivered</span>'
      : '<span style="background:rgba(0,117,255,.15);color:var(--accent2);border-radius:4px;padding:1px 6px;font-size:10px">Sent</span>';
    return `<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);flex-wrap:wrap">
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${esc(e.subject)}</div>
        <div style="font-size:10px;color:var(--muted);margin-top:2px">To: ${esc(e.toName)} &nbsp;·&nbsp; ${ts} &nbsp;·&nbsp; ${esc(e.rfq)}</div>
      </div>
      <div style="display:flex;align-items:center;gap:6px;flex-shrink:0">${badge}${ticks}</div>
    </div>`;
  }).join('');
}
// ── END EMAIL STATUS ──────────────────────────────────────────────────
const esc=s=>(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
const fR=n=>'R '+parseFloat(n||0).toLocaleString('en-ZA',{minimumFractionDigits:2,maximumFractionDigits:2});

// ── PASSWORD AUTH ──────────────────────────────────────────────────────────
const ROLE_EMAILS={chris:'chris.schoeman@microtronix.co.za',miranda:'miranda@microtronix.co.za',melanie:'melanie@microtronix.co.za',maxine:'maxine@microtronix.co.za',procurement:'angelas@microtronix.co.za',manufacturing:'hamesh@microtronix.co.za'};
const ROLE_NAMES={chris:'Chris',miranda:'Miranda',melanie:'Melanie',maxine:'Maxine',procurement:'Procurement',manufacturing:'Manufacturing'};

async function hashPwd(pw){const d=new TextEncoder().encode(pw+'mtx-salt-v1');const h=await crypto.subtle.digest('SHA-256',d);return Array.from(new Uint8Array(h)).map(b=>b.toString(16).padStart(2,'0')).join('');}
function storedHash(email){return localStorage.getItem('mtx_h_'+email.toLowerCase());}
function saveHash(email,hash){localStorage.setItem('mtx_h_'+email.toLowerCase(),hash);}
function hasPassword(email){return!!storedHash(email.toLowerCase());}

let _r='';
function pickRole(r,el){
  _r=r;
  document.querySelectorAll('.rb').forEach(b=>b.classList.remove('sel'));
  el.classList.add('sel');
  const email=ROLE_EMAILS[r]||'';
  document.getElementById('pw-email-show').textContent=email;
  document.getElementById('pw-input').value='';
  document.getElementById('pw-confirm').value='';
  const msg=document.getElementById('pw-msg');
  msg.style.display='none';msg.textContent='';
  if(hasPassword(email)){
    document.getElementById('pw-label').textContent='Password';
    document.getElementById('pw-confirm-wrap').style.display='none';
    msg.style.background='rgba(0,117,255,.08)';msg.style.color='var(--accent2)';
    msg.textContent='Welcome back, '+ROLE_NAMES[r]+'! Enter your password to continue.';
    msg.style.display='block';
  } else {
    document.getElementById('pw-label').textContent='Create Password';
    document.getElementById('pw-confirm-wrap').style.display='block';
    msg.style.background='rgba(0,229,160,.08)';msg.style.color='var(--accent)';
    msg.textContent='First time? Set a password for your account.';
    msg.style.display='block';
  }
  document.getElementById('pw-pre').style.display='none';
  document.getElementById('pw-section').style.display='block';
  document.getElementById('pw-input').focus();
}

async function enterApp(){
  if(!_r)return;
  const email=ROLE_EMAILS[_r]||'';
  const pw=document.getElementById('pw-input').value;
  const confirm=document.getElementById('pw-confirm').value;
  const msg=document.getElementById('pw-msg');
  if(!pw){msg.style.background='rgba(255,107,53,.1)';msg.style.color='var(--accent3)';msg.textContent='Please enter a password.';msg.style.display='block';return;}
  if(!hasPassword(email)){
    if(pw.length<6){msg.style.background='rgba(255,107,53,.1)';msg.style.color='var(--accent3)';msg.textContent='Password must be at least 6 characters.';msg.style.display='block';return;}
    if(pw!==confirm){msg.style.background='rgba(255,107,53,.1)';msg.style.color='var(--accent3)';msg.textContent='Passwords do not match.';msg.style.display='block';return;}
    const h=await hashPwd(pw); saveHash(email,h);
  } else {
    const h=await hashPwd(pw);
    if(h!==storedHash(email)){msg.style.background='rgba(255,107,53,.1)';msg.style.color='var(--accent3)';msg.textContent='Incorrect password. Try again.';msg.style.display='block';return;}
  }
  _launchApp(_r,false);
}

function enterAsGuest(){
  _launchApp(null,true);
}

function _launchApp(role,guest){
  S.role=role||'guest'; S.isGuest=guest;
  const name=role?ROLE_NAMES[role]:'Guest';
  document.getElementById('rdsp').textContent=name;
  document.getElementById('wo').style.display='none';
  document.getElementById('app').style.display='block';
  document.getElementById('r-d').value=new Date().toISOString().split('T')[0];
  S.bomRows=DBOM.map(r=>({...r,supplier:''}));
  renderDash();
  if(guest) toast('👁','Guest Mode','Dashboard is read-only. Login to make changes.');
  else toast('👋','Welcome, '+name+'!','Start from the Dashboard or log a new RFQ.');
}

// ── REQUIRE AUTH WRAPPER ──────────────────────────────────────────────────
let _authCallback=null;
function requireAuth(fn){
  if(!S.isGuest){fn();return;}
  toast('🔐','Login Required','Guests cannot make changes. Please reload and log in.');
}
function authModalCancel(){document.getElementById('auth-modal').classList.remove('show');_authCallback=null;}
async function authModalConfirm(){
  const email=document.getElementById('auth-modal-email').value;
  const pw=document.getElementById('auth-modal-pwd').value;
  const msg=document.getElementById('auth-modal-msg');
  if(!pw){msg.style.background='rgba(255,107,53,.1)';msg.style.color='var(--accent3)';msg.textContent='Enter your password.';msg.style.display='block';return;}
  const h=await hashPwd(pw);
  if(h===storedHash(email)){
    document.getElementById('auth-modal').classList.remove('show');
    if(_authCallback){_authCallback();_authCallback=null;}
  } else {
    msg.style.background='rgba(255,107,53,.1)';msg.style.color='var(--accent3)';msg.textContent='Incorrect password.';msg.style.display='block';
  }
}

// NAV
function goStage(n){
  if(S.isGuest&&n>0){toast('🔐','Login Required','Guests can only view the Dashboard. Please reload and log in to access workflow stages.');return;}
  if(n>1&&n>S.cur&&!S.done.includes(n-1))return;
  showP(n);
}
function showP(n){document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));document.getElementById('panel-'+n).classList.add('active');S.cur=n;
  for(let i=0;i<=8;i++){
    const nav=document.getElementById('nav-'+i),st=document.getElementById('st-'+i),mn=document.getElementById('mnav-'+i);
    if(!nav||!st)continue;
    nav.classList.remove('active','locked');st.classList.remove('active','done');
    if(mn){mn.classList.remove('active','locked');}
    if(i===n){nav.classList.add('active');st.classList.add('active');if(mn)mn.classList.add('active');}
    else if(S.done.includes(i)||i===0||i===1||i<n){st.classList.add('done');st.onclick=()=>goStage(i);}
    else{nav.classList.add('locked');if(mn)mn.classList.add('locked');}
  }
  window.scrollTo({top:0,behavior:'smooth'});
}
function done(n){if(!S.done.includes(n))S.done.push(n);syncRFQ();renderDash();}

// TOAST
function toast(ic,tt,tm){['ti','tt','tm'].forEach((id,j)=>document.getElementById(id).textContent=[ic,tt,tm][j]);const t=document.getElementById('toast');t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),4200);}

// SIDEBAR
function sb(){document.getElementById('sb-c').textContent=S.cust||'—';document.getElementById('sb-p').textContent=S.pcb||'—';document.getElementById('sb-q').textContent=S.qty||'—';document.getElementById('sb-k').textContent=S.kam||'—';}

// DASHBOARD
function syncRFQ(){
  if(!S.rfqId) return;
  const idx=RFQS.findIndex(r=>r.id===S.rfqId);
  const rec={
    id:S.rfqId, cust:S.cust, pcb:S.pcb, qty:S.qty, bpp:S.bpp,
    kam:S.kam, approver:S.approver, stage:S.cur,
    done:[...S.done], quote:S.qpb||0,
    bomRows:S.bomRows.map(r=>({...r})),
    bomVerifyRows:S.bomVerifyRows.map(r=>({...r})),
    procRows:S.procRows.map(r=>({...r})),
    labRows:S.labRows.map(r=>({...r})),
    compTot:S.compTot, srcTot:S.srcTot, moqTot:S.moqTot,
    labTot:S.labTot, markup:S.markup, qpb:S.qpb, otot:S.otot
  };
  if(idx>=0) RFQS[idx]=rec; else RFQS.push(rec);
}
function renderDash(){
  const tot=RFQS.length,app=RFQS.filter(r=>r.stage===8).length,prog=RFQS.filter(r=>r.stage>0&&r.stage<8).length,pend=RFQS.filter(r=>r.stage>=4&&r.stage<8).length;
  document.getElementById('ds-tot').textContent=tot;document.getElementById('ds-app').textContent=app;document.getElementById('ds-open').textContent=prog;document.getElementById('ds-pend').textContent=pend;
  const list=document.getElementById('rfq-list');
  if(!RFQS.length){list.innerHTML='<div class="empty-dash"><div class="ei">📋</div><p>No RFQs logged yet.<br>Click <strong>+ New RFQ</strong> to get started.</p></div>';return;}
  list.innerHTML=RFQS.map((r,i)=>{
    const sc=STAGE_COLORS_MAP[r.stage]||'#5c6070',sl=SLABELS[r.stage]||'—';
    return `<div class="rfq-row" onclick="jumpRFQ(${i})">
      <div style="font-size:11px;color:var(--accent2)">${esc(r.id)}</div>
      <div><div style="font-weight:500">${esc(r.cust)}</div><div style="font-size:10px;color:var(--muted)">${esc(r.pcb)}</div></div>
      <div style="font-size:11px">${esc(r.kam)||'—'}</div>
      <div><span class="tag" style="background:${sc}18;color:${sc}">${sl}</span></div>
      <div style="font-size:11px;color:var(--text)">${esc(r.approver)||'—'}</div>
      <div style="font-size:11px;color:var(--accent)">${r.quote?fR(r.quote):'—'}</div>
    </div>`;
  }).join('');
}
const STAGE_COLORS_MAP={0:'#5c6070',1:'#f7c948',2:'#f7c948',3:'#0075ff',4:'#9b59b6',5:'#ff6b35',6:'#ff6b35',7:'#0075ff',8:'#00e5a0'};
function jumpRFQ(i){
  const r=RFQS[i];
  // Restore full state from saved record
  S.rfqId=r.id; S.cust=r.cust; S.pcb=r.pcb; S.qty=r.qty||30; S.bpp=r.bpp||6;
  S.kam=r.kam||''; S.approver=r.approver||''; S.done=r.done||[];
  S.bomRows=r.bomRows||[]; S.bomVerifyRows=r.bomVerifyRows||[]; S.procRows=r.procRows||[]; S.labRows=r.labRows||[];
  S.compTot=r.compTot||0; S.srcTot=r.srcTot||0; S.moqTot=r.moqTot||0;
  S.labTot=r.labTot||0; S.markup=r.markup||40; S.qpb=r.qpb||0; S.otot=r.otot||0;
  // Update sidebar
  sb();
  document.getElementById('rfq-id').textContent=S.rfqId;
  // Restore stage-specific UI
  const st=r.stage||1;
  if(st>=1){
    document.getElementById('r-c').value=S.cust;
    document.getElementById('r-p').value=S.pcb;
  }
  if(st>=2&&S.kam){
    autoKAMRestore();
  }
  if(st>=3){
    document.getElementById('k-c').textContent=S.cust;
    document.getElementById('k-p').textContent=S.pcb;
    document.getElementById('k-q').value=S.qty;
    document.getElementById('k-bpp').value=S.bpp;
    document.getElementById('k-pan').textContent=Math.ceil(S.qty/S.bpp);
    document.getElementById('k3who').innerHTML='<div class="coi">📨</div><div class="cot"><strong>Resuming: '+S.cust+' — '+S.pcb+'</strong><br>KAM: '+S.kam+' | Approver: '+(S.approver||'Not set')+'</div>';
    if(S.approver){
      document.querySelectorAll('.appr-c').forEach(c=>{
        if(c.getAttribute('data-name')===S.approver) c.classList.add('sel');
        else c.classList.remove('sel');
      });
    }
    renderBOM();
  }
  if(st>=4&&S.bomVerifyRows.length) renderBOMVerifyTable();
  if(st>=5&&S.procRows.length) buildProc();
  if(st>=6&&S.labRows.length) buildLab();
  if(st>=7) buildApproval();
  if(st>=8) buildSAP();
  showP(st);
  toast('📂','RFQ Loaded','Opened '+r.id+' at stage: '+SLABELS[st]);
}

