const SCOLORS=['#5c6070','#f7c948','#f7c948','#0075ff','#9b59b6','#ff6b35','#ff6b35','#0075ff','#00e5a0'];

const EMAILS={
  Chris:'chris.schoeman@microtronix.co.za',
