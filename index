    else if(st==='mismatch'||st==='manual-fail'){rowCls='bv-row-mismatch';badge='<span class="bv-badge mismatch">✗ Mismatch</span>';}
    else{rowCls='bv-row-pending';badge='<span class="bv-badge pending">○ Pending</span>';}
    const foundDesc=r.foundDesc?`<span style="font-size:11px;color:var(--label)">${esc(r.foundDesc)}</span>`:'<span style="color:var(--muted);font-size:11px">—</span>';
