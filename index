<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="MTX Quotes">
<meta name="application-name" content="MTX Quotes">
<meta name="theme-color" content="#0e0f13">
<meta name="description" content="Microtronix PCB Quote Workflow System">
<title>Microtronix — PCB Quote Workflow</title>
<link rel="manifest" id="manifest-link">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<script>
// PWA Manifest (inline)
const manifestData = {
  name: "Microtronix Quote Workflow",
  short_name: "MTX Quotes",
  description: "Microtronix PCB Quote Workflow System",
  start_url: "./",
  display: "standalone",
  background_color: "#0e0f13",
  theme_color: "#0e0f13",
  orientation: "any",
  icons: [
    { src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'%3E%3Crect width='192' height='192' fill='%230e0f13' rx='24'/%3E%3Ctext x='50%25' y='55%25' font-size='110' text-anchor='middle' dominant-baseline='middle' fill='%2300e5a0'%3E⚡%3C/text%3E%3C/svg%3E", sizes: "192x192", type: "image/svg+xml" },
    { src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' fill='%230e0f13' rx='64'/%3E%3Ctext x='50%25' y='55%25' font-size='300' text-anchor='middle' dominant-baseline='middle' fill='%2300e5a0'%3E⚡%3C/text%3E%3C/svg%3E", sizes: "512x512", type: "image/svg+xml" }
  ]
};
const manifestBlob = new Blob([JSON.stringify(manifestData)], {type:'application/json'});
const manifestURL = URL.createObjectURL(manifestBlob);
document.getElementById('manifest-link').href = manifestURL;

// Service Worker for offline / home screen
if ('serviceWorker' in navigator) {
  const swCode = `
    const CACHE = 'mtx-quotes-v1';
    self.addEventListener('install', e => { self.skipWaiting(); });
    self.addEventListener('activate', e => { e.waitUntil(self.clients.claim()); });
    self.addEventListener('fetch', e => { e.respondWith(fetch(e.request).catch(() => new Response('Offline'))); });
  `;
  const swBlob = new Blob([swCode], {type:'application/javascript'});
  const swURL = URL.createObjectURL(swBlob);
  navigator.serviceWorker.register(swURL).catch(()=>{});
}
</script>
<style>
:root {
  --bg:#0e0f13;--surface:#16181f;--surface2:#1e2029;--border:#2a2d38;
  --accent:#00e5a0;--accent2:#0075ff;--accent3:#ff6b35;--warn:#f7c948;
  --text:#e8eaf0;--muted:#5c6070;--label:#8b90a0;
  --radius:10px;
  --font-head:'Syne',sans-serif;--font-mono:'DM Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font-mono);font-size:13px;min-height:100vh}

/* WELCOME */
#wo{position:fixed;inset:0;background:linear-gradient(135deg,#05060a 0%,#0e1520 50%,#0a1628 100%);z-index:200;display:flex;align-items:flex-start;justify-content:center;padding:16px;overflow-y:auto;-webkit-overflow-scrolling:touch}
.wc{background:var(--surface);border:1px solid var(--border);border-radius:18px;max-width:560px;width:100%;box-shadow:0 32px 80px rgba(0,0,0,.7);animation:up .5s cubic-bezier(.34,1.56,.64,1);overflow:visible;margin:auto}
@keyframes up{from{opacity:0;transform:translateY(36px) scale(.97)}to{opacity:1;transform:none}}
.wc-header{background:#000;padding:22px 28px 18px;text-align:center;border-bottom:1px solid var(--border);border-radius:18px 18px 0 0}
.wc-logo{max-width:240px;height:auto;display:block;margin:0 auto}
.wc-body{padding:22px 28px 26px}
.wc-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(0,229,160,.1);border:1px solid rgba(0,229,160,.25);border-radius:20px;padding:4px 12px;font-size:10px;font-weight:500;color:var(--accent);letter-spacing:1px;margin-bottom:12px}
.wc-title{font-family:var(--font-head);font-size:20px;font-weight:800;color:var(--text);letter-spacing:-.3px;margin-bottom:14px;line-height:1.25}
.wc-title span{color:var(--accent)}
.wc-msg{background:rgba(0,117,255,.07);border-left:3px solid var(--accent2);border-radius:0 8px 8px 0;padding:12px 14px;margin-bottom:18px;font-size:12.5px;line-height:1.75;color:var(--text)}
.wc-from{font-size:10px;font-weight:500;color:var(--accent2);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.wc-div{border:none;border-top:1px solid var(--border);margin:16px 0}
.wc-sub{font-size:10px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px}
.rg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.rb{border:1px solid var(--border);border-radius:var(--radius);padding:11px 12px;cursor:pointer;background:var(--surface2);transition:all .18s;display:flex;align-items:center;gap:10px;-webkit-tap-highlight-color:transparent}
.rb:hover,.rb:active{border-color:var(--accent);background:rgba(0,229,160,.06)}
.rb.sel{border-color:var(--accent);background:rgba(0,229,160,.08);box-shadow:0 0 0 2px rgba(0,229,160,.15)}
.ri{font-size:19px;flex-shrink:0}
.rn{font-family:var(--font-head);font-weight:600;font-size:13px;color:var(--text)}
.rd{font-size:11px;color:var(--muted);margin-top:1px}
.be{width:100%;padding:15px;background:var(--accent);color:#000;border:none;border-radius:var(--radius);font-family:var(--font-mono);font-size:14px;font-weight:500;cursor:pointer;transition:all .18s;-webkit-tap-highlight-color:transparent;margin-top:4px}
.be:active{background:#00ffb3;transform:scale(.98)}
.be:disabled{opacity:.4;cursor:not-allowed;background:var(--muted)}
.wc-foot{text-align:center;margin-top:12px;font-size:11px;color:var(--muted);padding-bottom:4px}
.wc-foot a{color:var(--accent);text-decoration:none}

/* APP */
#app{display:none}
.ah{background:var(--surface);border-bottom:1px solid var(--border);padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.ah-logo{height:32px;width:auto}
.ah-r{display:flex;align-items:center;gap:10px}
.chip{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:4px 11px;font-size:10px;color:var(--muted)}
.chip strong{color:var(--accent)}
.rpill{display:flex;align-items:center;gap:6px;background:rgba(0,229,160,.08);border:1px solid rgba(0,229,160,.2);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:500;color:var(--accent)}
.rpill .dot{width:7px;height:7px;border-radius:50%;background:var(--accent)}

/* STAGE BAR */
.stbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 28px;display:flex;overflow-x:auto}
.ss{display:flex;align-items:center;gap:7px;padding:13px 14px;font-size:11px;font-weight:500;color:var(--muted);border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s;cursor:default}
.ss.done{color:var(--accent);border-bottom-color:var(--accent);cursor:pointer}
.ss.active{color:var(--text);border-bottom-color:var(--accent2);font-weight:500}
.sn{width:20px;height:20px;border-radius:50%;background:var(--surface2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}
.ss.done .sn{background:var(--accent);border-color:var(--accent);color:#000}
.ss.active .sn{background:var(--accent2);border-color:var(--accent2);color:#fff}

/* LAYOUT */
.ab{display:flex;align-items:flex-start}
.sidebar{width:230px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);padding:18px 10px;display:flex;flex-direction:column;gap:3px;position:sticky;top:0;height:100vh;overflow-y:auto}
.sl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;padding:8px 10px 5px}
.nav{display:flex;align-items:center;gap:9px;padding:9px 11px;border-radius:var(--radius);cursor:pointer;color:var(--label);font-size:12px;transition:all .15s;border:1px solid transparent}
.nav:hover{background:var(--surface2);color:var(--text)}
.nav.active{background:rgba(0,229,160,.08);color:var(--accent);border-color:rgba(0,229,160,.2)}
.nav.locked{opacity:.35;cursor:not-allowed}
.ni{width:20px;text-align:center;font-size:14px}
.qib{margin-top:auto;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px}
.qr{display:flex;flex-direction:column;gap:2px;margin-bottom:8px}
.qr:last-child{margin-bottom:0}
.ql{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px}
.qv{color:var(--text);font-size:12px}

.content{flex:1;padding:26px 30px;min-width:0}

/* RESPONSIVE — TABLET */
@media(max-width:900px){
  .sidebar{width:190px;padding:14px 8px}
  .content{padding:20px 18px}
  .dash-stats{grid-template-columns:1fr 1fr}
  .rfq-hdr,.rfq-row{grid-template-columns:90px 1fr 80px 100px}
  .rfq-hdr div:nth-child(5),.rfq-hdr div:nth-child(6),
  .rfq-row div:nth-child(5),.rfq-row div:nth-child(6){display:none}
  .g2{grid-template-columns:1fr}
  .g3{grid-template-columns:1fr 1fr}
  .svcg{grid-template-columns:1fr 1fr}
  .appr-g{grid-template-columns:1fr 1fr}
}

/* RESPONSIVE — MOBILE */
@media(max-width:640px){
  /* Header */
  .ah{padding:0 14px;height:52px}
  .ah-logo{height:28px}
  .chip{display:none}

  /* Stage bar — compact icons only */
  .stbar{padding:0 8px}
  .ss{padding:10px 8px;font-size:10px;gap:5px}
  .ss .stage-label{display:none}

  /* Hide sidebar, show bottom nav instead */
  .sidebar{display:none}
  .content{padding:16px 14px}

  /* Bottom nav bar for mobile */
  .mob-nav{display:flex!important}

  /* Cards */
  .card{padding:16px 14px}
  .ct{font-size:14px}

  /* Forms — all single column */
  .g2,.g3{grid-template-columns:1fr}
  .svcg{grid-template-columns:1fr 1fr}
  .appr-g{grid-template-columns:1fr 1fr}

  /* Buttons — full width on mobile */
  .br{flex-direction:column}
  .br .btn{width:100%;justify-content:center;padding:14px 18px;font-size:14px}

  /* Dashboard stats */
  .dash-stats{grid-template-columns:1fr 1fr;gap:10px}
  .stat-n{font-size:24px}

  /* Dashboard table — simplify */
  .rfq-hdr,.rfq-row{grid-template-columns:1fr 1fr;gap:8px;padding:10px 12px}
  .rfq-hdr div:nth-child(n+3),.rfq-row div:nth-child(n+3){display:none}

  /* Cost boxes */
  .csec+.csec{margin-top:10px}
  div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;gap:10px!important}

  /* KAM cards */
  .kc{flex-direction:column;align-items:flex-start;gap:10px}
  .kc>div:last-child{text-align:left}

  /* Welcome */
  .wc-body{padding:20px 18px 24px}
  .rg{grid-template-columns:1fr 1fr}
  .wc-title{font-size:18px}

  /* Rejection panel */
  .g2{gap:10px}

  /* Welcome card */
  .wc{border-radius:14px}
  .wc-header{padding:20px 18px}
  .wc-logo{max-width:200px}
}

/* Mobile bottom nav */
.mob-nav{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--border);z-index:99;padding:8px 4px;gap:2px;justify-content:space-around}
.mob-btn{display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 10px;border-radius:8px;cursor:pointer;color:var(--muted);font-size:9px;border:none;background:transparent;font-family:var(--font-mono);transition:all .15s;flex:1;max-width:70px}
.mob-btn.active{color:var(--accent);background:rgba(0,229,160,.08)}
.mob-btn.locked{opacity:.3;cursor:not-allowed}
.mob-icon{font-size:18px}

/* Add bottom padding on mobile so content isn't hidden behind nav */
@media(max-width:640px){
  body{padding-bottom:72px}
}

/* CARDS */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;margin-bottom:16px}
.ct{font-family:var(--font-head);font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:9px}
.cs{font-size:12px;color:var(--muted);margin-bottom:17px}

/* FORMS */
.fg{display:flex;flex-direction:column;gap:5px}
.fg.full{grid-column:1/-1}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:13px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px}
label{font-size:11px;color:var(--label);text-transform:uppercase;letter-spacing:.4px}
input,select,textarea{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:9px 11px;color:var(--text);font-family:var(--font-mono);font-size:12px;outline:none;transition:border-color .15s;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--accent2)}
select option{background:var(--surface2)}
textarea{resize:vertical;min-height:72px}
input[type="checkbox"]{width:auto;accent-color:var(--accent);cursor:pointer}
.ro{padding:9px 11px;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:7px;color:var(--muted);font-size:12px}

/* BUTTONS */
.btn{padding:11px 18px;border-radius:8px;border:none;cursor:pointer;font-family:var(--font-mono);font-size:12px;font-weight:500;transition:all .15s;display:inline-flex;align-items:center;gap:7px;-webkit-tap-highlight-color:transparent;touch-action:manipulation}
.bp{background:var(--accent);color:#000}
.bp:active{background:#00ffb3;transform:scale(.97)}
.bb{background:var(--accent2);color:#fff}
.bb:active{background:#2a8fff}
.bg{background:rgba(0,229,160,.15);color:var(--accent);border:1px solid rgba(0,229,160,.3)}
.bg:active{background:rgba(0,229,160,.25)}
.bo{background:var(--surface2);color:var(--text);border:1px solid var(--border)}
.bo:active{border-color:var(--accent2);color:var(--accent2)}
.bd{background:rgba(255,69,69,.1);color:#ff4545;border:1px solid rgba(255,69,69,.2)}
.bd:active{background:rgba(255,69,69,.2)}
.blg{padding:14px 24px;font-size:14px}
.br{display:flex;gap:10px;margin-top:20px;flex-wrap:wrap;align-items:center}

/* INSTALL BANNER */
#install-banner{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--accent);padding:12px 16px;z-index:150;align-items:center;justify-content:space-between;gap:12px;box-shadow:0 -4px 20px rgba(0,0,0,.4)}
#install-banner.show{display:flex}
.install-text{font-size:12px;color:var(--text);flex:1}
.install-text strong{color:var(--accent);display:block;margin-bottom:2px}
.install-btns{display:flex;gap:8px;flex-shrink:0}
.install-ios{display:none}
@media(max-width:640px){
  #install-banner{padding:10px 14px}
  .install-text{font-size:11px}
}

/* TABLES */
.dt{width:100%;border-collapse:collapse;font-size:12px}
.dt th{text-align:left;padding:8px 11px;background:var(--surface2);color:var(--label);font-size:10px;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border)}
.dt td{padding:7px 11px;border-bottom:1px solid rgba(42,45,56,.5);color:var(--text);vertical-align:middle}
.dt tr:last-child td{border-bottom:none}
.dt tr:hover td{background:rgba(255,255,255,.02)}
.dt td input,.dt td select{padding:5px 8px;font-size:12px}
.dt tfoot td{padding:9px 11px;font-weight:500;background:var(--surface2);border-top:1px solid var(--border);border-bottom:none}
.del{background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:14px;padding:2px 5px;border-radius:4px;transition:all .15s}
.del:hover{color:#ff4545}
.addr{width:100%;margin-top:7px;background:transparent;border:1px dashed var(--border);border-radius:7px;padding:8px;color:var(--muted);font-family:var(--font-mono);font-size:12px;cursor:pointer;transition:all .15s}
.addr:hover{border-color:var(--accent);color:var(--accent)}

/* TAGS */
.tag{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:.4px;white-space:nowrap}
.tg{background:rgba(0,229,160,.12);color:var(--accent)}
.tb{background:rgba(0,117,255,.12);color:var(--accent2)}
.tw{background:rgba(247,201,72,.12);color:var(--warn)}
.to{background:rgba(255,107,53,.12);color:var(--accent3)}

/* COST BOXES */
.csec{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px}
.cr{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border)}
.cr:last-child{border-bottom:none}
.crl{font-size:12px;color:var(--muted)}
.crv{font-size:12px;font-weight:500;color:var(--text)}
.grand{font-size:20px;font-family:var(--font-head);font-weight:700;color:var(--accent)}

/* CALLOUTS */
.co{border-radius:var(--radius);padding:12px 15px;margin-bottom:14px;display:flex;gap:11px;align-items:flex-start}
.coi{font-size:16px;flex-shrink:0;margin-top:1px}
.cot{line-height:1.6;font-size:12px}
.cot strong{display:block;font-weight:500;margin-bottom:3px;font-family:var(--font-head)}
.co.blue{background:rgba(0,117,255,.07);border:1px solid rgba(0,117,255,.2);color:var(--text)}
.co.green{background:rgba(0,229,160,.07);border:1px solid rgba(0,229,160,.2);color:var(--text)}
.co.warn{background:rgba(247,201,72,.07);border:1px solid rgba(247,201,72,.2);color:var(--text)}

/* KAM CARDS */
.kc{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-radius:var(--radius);background:var(--surface2);border:1px solid var(--border);cursor:pointer;transition:all .18s}
.kc:hover{border-color:var(--accent2)}
.kc.sel{border-color:var(--accent);background:rgba(0,229,160,.06)}
.ki{display:flex;align-items:center;gap:11px}
.kav{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;font-family:var(--font-head);flex-shrink:0}
.kn{font-family:var(--font-head);font-weight:600;font-size:14px;color:var(--text)}
.kr{font-size:11px;color:var(--muted)}
.wb{width:90px;height:4px;background:var(--border);border-radius:3px;overflow:hidden;margin-top:5px}
.wf{height:100%;border-radius:3px;transition:width .5s ease}

/* APPROVER CARDS */
.appr-g{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.appr-c{border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;cursor:pointer;background:var(--surface2);transition:all .18s;display:flex;align-items:center;gap:12px}
.appr-c:hover{border-color:var(--accent2)}
.appr-c.sel{border-color:var(--accent);background:rgba(0,229,160,.06)}
.appr-av{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:700;color:#fff;font-family:var(--font-head);flex-shrink:0}

/* SAP ROWS */
.sr{display:grid;grid-template-columns:195px 1fr;gap:8px;padding:8px 0;border-bottom:1px solid rgba(42,45,56,.5);align-items:center}
.sr:last-child{border-bottom:none}
.sk{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.sv{font-size:12px;color:var(--text)}

/* SERVICES */
.svcg{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.svci{display:flex;align-items:center;gap:8px;padding:9px 11px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;cursor:pointer;transition:all .15s}
.svci:hover{border-color:var(--accent)}
.svci input{flex-shrink:0;width:13px;height:13px}
.svci label{font-size:12px;cursor:pointer;margin:0;text-transform:none;letter-spacing:0;color:var(--text)}

/* DASHBOARD */
.dash-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px}
.stat-n{font-family:var(--font-head);font-size:28px;font-weight:800;color:var(--accent);line-height:1}
.stat-l{font-size:11px;color:var(--muted);margin-top:4px}
.rfq-hdr{display:grid;grid-template-columns:100px 1fr 80px 120px 80px 90px;gap:10px;padding:8px 14px;background:var(--surface2);border-bottom:1px solid var(--border);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.rfq-row{display:grid;grid-template-columns:100px 1fr 80px 120px 80px 90px;gap:10px;align-items:center;padding:10px 14px;border-bottom:1px solid rgba(42,45,56,.4);font-size:12px;transition:background .15s;cursor:pointer}
.rfq-row:hover{background:rgba(255,255,255,.02)}
.rfq-row:last-child{border-bottom:none}
.empty-dash{padding:40px;text-align:center;color:var(--muted)}
.empty-dash .ei{font-size:38px;margin-bottom:10px}
.empty-dash p{font-size:12px;line-height:1.6}

/* MISC */
hr.dv{border:none;border-top:1px solid var(--border);margin:17px 0}
.sh{font-size:12px;font-weight:500;color:var(--text);margin-bottom:10px;margin-top:2px;font-family:var(--font-head)}
.ph{font-family:var(--font-head);font-size:20px;font-weight:800;color:var(--text);margin-bottom:4px;letter-spacing:-.3px}
.ps{font-size:12px;color:var(--muted);margin-bottom:18px}
.mt4{margin-top:14px}
.ta{color:var(--accent)}.tb2{color:var(--accent2)}.fw7{font-weight:600}
.panel{display:none}.panel.active{display:block}

/* TOAST */
#toast{position:fixed;bottom:22px;right:22px;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:13px 17px;font-size:12px;color:var(--text);box-shadow:0 8px 40px rgba(0,0,0,.5);z-index:999;max-width:300px;transform:translateY(65px);opacity:0;transition:all .35s cubic-bezier(.34,1.56,.64,1);display:flex;gap:11px;align-items:flex-start}
#toast.show{transform:translateY(0);opacity:1}
.ti{font-size:18px;flex-shrink:0}.tt{font-weight:500;margin-bottom:2px;font-family:var(--font-head)}.tm{font-size:11px;color:var(--label)}

@media print{.ah,.stbar,.sidebar,.br,#toast{display:none!important}.content{padding:0}.card{border:1px solid #333}}

/* BOM VERIFICATION */
.bv-row-pending{background:rgba(247,201,72,.06);border-left:3px solid var(--warn)}
.bv-row-match{background:rgba(0,229,160,.07);border-left:3px solid var(--accent)}
.bv-row-mismatch{background:rgba(255,107,53,.08);border-left:3px solid var(--accent3)}
.bv-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:12px;font-size:10px;font-weight:500}
.bv-badge.pending{background:rgba(247,201,72,.15);color:var(--warn)}
.bv-badge.match{background:rgba(0,229,160,.15);color:var(--accent)}
.bv-badge.mismatch{background:rgba(255,107,53,.15);color:var(--accent3)}
.bv-badge.manual{background:rgba(0,117,255,.15);color:var(--accent2)}
.bv-prog{display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--surface2);border-radius:var(--radius);margin-bottom:14px;font-size:12px}
.bv-bar-wrap{flex:1;background:var(--border);border-radius:4px;height:6px;overflow:hidden}
.bv-bar{height:6px;border-radius:4px;background:var(--accent);transition:width .4s}
.bv-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.bv-stat{background:var(--surface2);border-radius:var(--radius);padding:10px 12px;text-align:center}
.bv-stat-n{font-size:22px;font-weight:700;font-family:var(--font-head)}
.bv-stat-l{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-top:2px}
.search-links{display:flex;gap:5px;flex-wrap:wrap}
.search-link{font-size:10px;padding:3px 7px;border-radius:5px;background:rgba(0,117,255,.12);color:var(--accent2);text-decoration:none;border:1px solid rgba(0,117,255,.2)}
.search-link:hover{background:rgba(0,117,255,.22)}

/* AUTH MODAL */
#auth-modal{position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:300;display:none;align-items:center;justify-content:center;padding:16px}
#auth-modal.show{display:flex}
.auth-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;max-width:420px;width:100%;padding:28px;box-shadow:0 24px 60px rgba(0,0,0,.6);animation:up .35s cubic-bezier(.34,1.56,.64,1)}
.auth-title{font-family:var(--font-head);font-size:17px;font-weight:700;margin-bottom:4px}
.auth-sub{font-size:12px;color:var(--muted);margin-bottom:20px}
.auth-field{margin-bottom:14px}
.auth-field label{display:block;font-size:11px;color:var(--label);margin-bottom:5px;text-transform:uppercase;letter-spacing:.7px}
.auth-field input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:11px 14px;color:var(--text);font-family:var(--font-mono);font-size:13px}
.auth-field input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 2px rgba(0,229,160,.12)}
.auth-hint{font-size:11px;color:var(--muted);margin-top:4px}
.auth-btns{display:flex;gap:8px;margin-top:4px}
.auth-cancel{flex:1;padding:11px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--label);font-family:var(--font-mono);font-size:13px;cursor:pointer}
.auth-cancel:hover{border-color:var(--text);color:var(--text)}

/* WELCOME PASSWORD */
#pw-section{display:none;margin-top:14px;border-top:1px solid var(--border);padding-top:14px}
.pw-email-disp{font-size:12px;color:var(--accent2);margin-bottom:10px;padding:8px 12px;background:rgba(0,117,255,.07);border-radius:6px}
.pw-field{margin-bottom:10px}
.pw-field label{display:block;font-size:10px;color:var(--label);text-transform:uppercase;letter-spacing:.7px;margin-bottom:4px}
.pw-field input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:10px 13px;color:var(--text);font-family:var(--font-mono);font-size:13px}
.pw-field input:focus{outline:none;border-color:var(--accent)}
.pw-msg{font-size:11px;margin-top:6px;padding:6px 10px;border-radius:6px;display:none}
.pw-msg.error{background:rgba(255,107,53,.12);color:var(--accent3);display:block}
.pw-msg.info{background:rgba(0,229,160,.1);color:var(--accent);display:block}
.guest-btn{width:100%;padding:11px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--label);font-family:var(--font-mono);font-size:12px;cursor:pointer;margin-top:8px;transition:all .15s}
.guest-btn:hover{border-color:var(--accent2);color:var(--accent2)}
</style>
</head>
<body>

<!-- WELCOME -->
<div id="wo">
<div class="wc">
  <div class="wc-header">
    <img class="wc-logo" src="data:image/png;base64," alt="Microtronix Manufacturing">
  </div>
  <div class="wc-body">
    <div class="wc-title" style="margin-top:8px">PCB Quote <span>Workflow System</span></div>
    <div class="wc-sub">Who are you today?</div>
    <div class="rg">
      <div class="rb" onclick="pickRole('chris',this)"><div class="ri">👔</div><div><div class="rn">Chris</div><div class="rd">Log RFQs &amp; approve quotes</div></div></div>
      <div class="rb" onclick="pickRole('miranda',this)"><div class="ri">👩‍💼</div><div><div class="rn">Miranda</div><div class="rd">Key Account Manager</div></div></div>
      <div class="rb" onclick="pickRole('melanie',this)"><div class="ri">👩‍💼</div><div><div class="rn">Melanie</div><div class="rd">Key Account Manager</div></div></div>
      <div class="rb" onclick="pickRole('maxine',this)"><div class="ri">👩‍💼</div><div><div class="rn">Maxine</div><div class="rd">Key Account Manager</div></div></div>
      <div class="rb" onclick="pickRole('procurement',this)"><div class="ri">🧩</div><div><div class="rn">Procurement</div><div class="rd">Component pricing &amp; MOQs</div></div></div>
      <div class="rb" onclick="pickRole('manufacturing',this)" style="grid-column:span 2"><div class="ri">🏭</div><div><div class="rn">Manufacturing</div><div class="rd">Labour costs &amp; production</div></div></div>
    </div>
    <!-- Password login section (shown after role is picked) -->
    <div id="pw-section" style="display:none;margin-top:14px;border-top:1px solid var(--border);padding-top:14px">
      <div class="pw-email-disp">📧 <span id="pw-email-show" style="font-weight:500"></span></div>
      <div class="pw-field" style="margin-top:10px">
        <label id="pw-label" style="display:block;font-size:10px;color:var(--label);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px">Password</label>
        <input type="password" id="pw-input" placeholder="Enter your password" autocomplete="current-password" style="width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:10px 13px;color:var(--text);font-family:var(--font-mono);font-size:13px">
      </div>
      <div id="pw-confirm-wrap" style="display:none;margin-top:8px" class="pw-field">
        <label style="display:block;font-size:10px;color:var(--label);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px">Confirm Password</label>
        <input type="password" id="pw-confirm" placeholder="Confirm new password" autocomplete="new-password" style="width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:10px 13px;color:var(--text);font-family:var(--font-mono);font-size:13px">
      </div>
      <div id="pw-msg" style="font-size:11px;margin-top:6px;padding:6px 10px;border-radius:6px;display:none"></div>
      <button class="be" id="ebe" onclick="enterApp()" style="margin-top:12px">Enter →</button>
    </div>
    <!-- Guest/pre-auth state -->
    <div id="pw-pre">
      <button class="be" id="ebe-pre" disabled style="margin-bottom:8px;background:var(--surface2);color:var(--muted);cursor:not-allowed">Select your role above to continue →</button>
      <button class="guest-btn" onclick="enterAsGuest()">👁 View Dashboard Only (No Login Required)</button>
    </div>
    <div class="wc-foot" style="margin-top:8px">Have feedback? <a href="mailto:chris.schoeman@microtronix.co.za?subject=Quote System Feedback">Email Chris directly</a></div>
  </div>
</div>
</div>

<!-- APP -->
<div id="app">
<header class="ah">
  <img class="ah-logo" src="data:image/png;base64," alt="Microtronix">
  <div class="ah-r">
    <button class="btn bo" onclick="goStage(0)" style="padding:6px 14px;font-size:11px;gap:5px">📊 Dashboard</button>
    <button class="btn bp" id="install-header-btn" onclick="headerInstall()" style="padding:6px 14px;font-size:11px;gap:5px">⬇️ Install App</button>
    <div class="chip">RFQ: <strong id="rfq-id">—</strong></div>
    <div class="rpill"><div class="dot"></div><span id="rdsp">—</span></div>
  </div>
</header>
<div class="stbar">
  <div class="ss active" id="st-0"><div class="sn">◉</div>Dashboard</div>
  <div class="ss" id="st-1"><div class="sn">1</div>RFQ Intake</div>
  <div class="ss" id="st-2"><div class="sn">2</div>KAM Assignment</div>
  <div class="ss" id="st-3"><div class="sn">3</div>KAM Details &amp; BOM</div>
  <div class="ss" id="st-4"><div class="sn">4</div><span class="stage-label">BOM Verify</span></div>
  <div class="ss" id="st-5"><div class="sn">5</div><span class="stage-label">Procurement</span></div>
  <div class="ss" id="st-6"><div class="sn">6</div><span class="stage-label">Manufacturing</span></div>
  <div class="ss" id="st-7"><div class="sn">7</div><span class="stage-label">Approval</span></div>
  <div class="ss" id="st-8"><div class="sn">8</div><span class="stage-label">SAP Summary</span></div>
</div>
<div class="ab">
<aside class="sidebar">
  <div class="sl">Navigation</div>
  <div class="nav active" id="nav-0" onclick="goStage(0)"><span class="ni">📊</span>Dashboard</div>
  <div class="nav" id="nav-1" onclick="goStage(1)"><span class="ni">📥</span>RFQ Intake</div>
  <div class="nav locked" id="nav-2"><span class="ni">👤</span>KAM Assignment</div>
  <div class="nav locked" id="nav-3"><span class="ni">📋</span>KAM Details</div>
  <div class="nav locked" id="nav-4"><span class="ni">🔍</span>BOM Verify</div>
  <div class="nav locked" id="nav-5"><span class="ni">🧩</span>Procurement</div>
  <div class="nav locked" id="nav-6"><span class="ni">🏭</span>Manufacturing</div>
  <div class="nav locked" id="nav-7"><span class="ni">✅</span>Approval</div>
  <div class="nav locked" id="nav-8"><span class="ni">📤</span>SAP Summary</div>
  <div class="qib">
    <div class="qr"><div class="ql">Customer</div><div class="qv" id="sb-c">—</div></div>
    <div class="qr"><div class="ql">PCB Name</div><div class="qv" id="sb-p">—</div></div>
    <div class="qr"><div class="ql">Quantity</div><div class="qv" id="sb-q">—</div></div>
    <div class="qr"><div class="ql">KAM</div><div class="qv" id="sb-k">—</div></div>
  </div>
</aside>
<main class="content">

<!-- DASHBOARD -->
<div class="panel active" id="panel-0">
  <div class="ph">Dashboard</div>
  <div class="ps">All open RFQs and their current stage at a glance.</div>
  <div class="dash-stats">
    <div class="stat-card"><div class="stat-n" id="ds-tot">0</div><div class="stat-l">Total RFQs</div></div>
    <div class="stat-card"><div class="stat-n" id="ds-open" style="color:var(--warn)">0</div><div class="stat-l">In Progress</div></div>
    <div class="stat-card"><div class="stat-n" id="ds-app" style="color:var(--accent)">0</div><div class="stat-l">Approved</div></div>
    <div class="stat-card"><div class="stat-n" id="ds-pend" style="color:var(--accent3)">0</div><div class="stat-l">Awaiting Action</div></div>
  </div>
  <div class="card" style="padding:0;overflow:hidden">
    <div style="padding:16px 18px 12px;display:flex;justify-content:space-between;align-items:center">
      <div style="font-family:var(--font-head);font-size:14px;font-weight:700">Open RFQ Tracker</div>
      <button class="btn bp" onclick="newRFQ()" style="padding:7px 14px;font-size:11px">+ New RFQ</button>
    </div>
    <div class="rfq-hdr"><div>RFQ ID</div><div>Customer / PCB</div><div>KAM</div><div>Stage</div><div>Approver</div><div>Quote / Board</div></div>
    <div id="rfq-list"><div class="empty-dash"><div class="ei">📋</div><p>No RFQs logged yet.<br>Click <strong>+ New RFQ</strong> to get started.</p></div></div>

    <!-- EMAIL STATUS LOG -->
    <div style="margin-top:24px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
        <div style="font-family:var(--font-head);font-size:13px;font-weight:700;color:var(--text)">📧 Email Activity</div>
        <div style="font-size:10px;color:var(--muted)">✓ = sent &nbsp;·&nbsp; ✓✓ grey = delivered &nbsp;·&nbsp; ✓✓ green = read</div>
      </div>
      <div id="email-log" style="font-size:12px"><div style="font-size:11px;color:var(--muted);padding:10px 0">No emails sent yet in this session.</div></div>
    </div>
  </div>
</div>

<!-- S1 RFQ INTAKE -->
<div class="panel" id="panel-1">
  <div class="ph">Log New RFQ</div>
  <div class="ps">Fill in customer and PCB details when an enquiry comes in. Takes about 60 seconds.</div>
  <div class="card">
    <div class="ct">📥 New Request for Quote</div><div class="cs">* Required fields</div>
    <div class="g2">
      <div class="fg"><label>Customer Name *</label><input id="r-c" placeholder="e.g. Monitech"></div>
      <div class="fg"><label>PCB / Product Name *</label><input id="r-p" placeholder="e.g. M102757"></div>
      <div class="fg"><label>Date Received</label><input type="date" id="r-d"></div>
      <div class="fg"><label>Logged By</label><input id="r-b" placeholder="Your name"></div>
      <div class="fg full"><label>Notes / Special Instructions</label><textarea id="r-n" placeholder="Urgency, preferred delivery date, special requirements..."></textarea></div>
    </div>
    <div class="br"><button class="btn bp blg" onclick="submitRFQ()">Submit RFQ &amp; Auto-Assign KAM →</button></div>
  </div>
</div>

<!-- S2 KAM ASSIGNMENT -->
<div class="panel" id="panel-2">
  <div class="ph">KAM Assignment</div>
  <div class="ps">Auto-assigned based on workload. Click a card to override.</div>
  <div class="co blue"><div class="coi">⚡</div><div class="cot"><strong>Auto-Assignment Logic</strong>The KAM with fewer active quotes gets assigned. Click a card below to override.</div></div>
  <div class="card">
    <div class="ct">👥 Team Workload</div>
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px">
      <div class="kc" id="kc-m" onclick="overrideKAM('Miranda')">
        <div class="ki"><div class="kav" style="background:linear-gradient(135deg,#0075ff,#7c3aed)">M</div><div><div class="kn">Miranda</div><div class="kr">Key Account Manager</div><div class="wb"><div class="wf" id="wl-m" style="width:50%;background:var(--accent2)"></div></div></div></div>
        <div style="text-align:right"><div style="font-family:var(--font-head);font-size:22px;font-weight:800" id="cnt-m">0</div><div style="font-size:10px;color:var(--muted)">active quotes</div></div>
      </div>
      <div class="kc" id="kc-mel" onclick="overrideKAM('Melanie')">
        <div class="ki"><div class="kav" style="background:linear-gradient(135deg,#f7c948,#ff6b35)">M</div><div><div class="kn">Melanie</div><div class="kr">Key Account Manager</div><div class="wb"><div class="wf" id="wl-mel" style="width:33%;background:var(--accent3)"></div></div></div></div>
        <div style="text-align:right"><div style="font-family:var(--font-head);font-size:22px;font-weight:800" id="cnt-mel">0</div><div style="font-size:10px;color:var(--muted)">active quotes</div></div>
      </div>
      <div class="kc" id="kc-max" onclick="overrideKAM('Maxine')">
        <div class="ki"><div class="kav" style="background:linear-gradient(135deg,#a855f7,#ec4899)">M</div><div><div class="kn">Maxine</div><div class="kr">Key Account Manager</div><div class="wb"><div class="wf" id="wl-max" style="width:33%;background:#a855f7"></div></div></div></div>
        <div style="text-align:right"><div style="font-family:var(--font-head);font-size:22px;font-weight:800" id="cnt-max">0</div><div style="font-size:10px;color:var(--muted)">active quotes</div></div>
      </div>
    </div>
    <div class="co green" id="abox" style="display:none"><div class="coi">✅</div><div class="cot"><strong id="amsg">Assigned</strong><span id="asub"></span></div></div>
    <div class="br"><button class="btn bp blg" onclick="confirmKAM()">✅ Confirm &amp; Notify KAM</button></div>
  </div>
</div>

<!-- S3 KAM DETAILS -->
<div class="panel" id="panel-3">
  <div class="ph">Customer Details &amp; BOM</div>
  <div class="ps">Enter order specs, select an approver, and fill in the bill of materials.</div>
  <div class="co blue" id="k3who"><div class="coi">📨</div><div class="cot"><strong>Assigned to you</strong>Complete the details below and submit to Procurement when ready.</div></div>
  <div class="card">
    <div class="ct">🏷️ Order Specifications</div>
    <div class="g2">
      <div class="fg"><label>Customer</label><div class="ro" id="k-c">—</div></div>
      <div class="fg"><label>PCB Name</label><div class="ro" id="k-p">—</div></div>
      <div class="fg"><label>Quantity of Boards *</label><input type="number" id="k-q" value="30" min="1" oninput="calcPanels()"></div>
      <div class="fg"><label>Boards per Panel</label><input type="number" id="k-bpp" value="6" min="1" oninput="calcPanels()"></div>
      <div class="fg"><label>Number of Panels (auto)</label><div class="ro" id="k-pan">5</div></div>
      <div class="fg"><label>PCB Class</label><select id="k-cls"><option>Class 2 — Standard</option><option>Class 3 — High Reliability</option></select></div>
      <div class="fg"><label>SMD Placements / Board</label><input type="number" id="k-smd" value="17" min="0"></div>
      <div class="fg"><label>Conv. Placements / Board</label><input type="number" id="k-conv" value="9" min="0"></div>
      <div class="fg"><label>BOM Line Items</label><input type="number" id="k-bom" value="13" min="0"></div>
    </div>
    <hr class="dv">
    <div class="sh">Additional Services Required</div>
    <div class="svcg">
      <div class="svci"><input type="checkbox" id="svc-cc"><label for="svc-cc">Conformal Coating</label></div>
      <div class="svci"><input type="checkbox" id="svc-wash"><label for="svc-wash">Washing</label></div>
      <div class="svci"><input type="checkbox" id="svc-prog"><label for="svc-prog">Programming</label></div>
      <div class="svci"><input type="checkbox" id="svc-test"><label for="svc-test">Testing</label></div>
      <div class="svci"><input type="checkbox" id="svc-assy"><label for="svc-assy">Assembly</label></div>
      <div class="svci"><input type="checkbox" id="svc-pack" checked><label for="svc-pack">Packing</label></div>
      <div class="svci"><input type="checkbox" id="svc-wave"><label for="svc-wave">Wave Solder</label></div>
      <div class="svci"><input type="checkbox" id="svc-aoi" checked><label for="svc-aoi">AOI</label></div>
    </div>
    <hr class="dv">
    <div class="sh">Who should approve this quote?</div>
    <div class="appr-g">
      <div class="appr-c" id="appr-chris" data-name="Chris" onclick="selAppr('Chris',this)">
        <div class="appr-av" style="background:linear-gradient(135deg,#0075ff,#0047b3)">C</div>
        <div><div style="font-family:var(--font-head);font-weight:600;font-size:14px">Chris</div><div style="font-size:11px;color:var(--muted)">Managing Director</div></div>
      </div>
      <div class="appr-c" id="appr-adam" data-name="Adam" onclick="selAppr('Adam',this)">
        <div class="appr-av" style="background:linear-gradient(135deg,#00e5a0,#00a370)">A</div>
        <div><div style="font-family:var(--font-head);font-weight:600;font-size:14px">Adam</div><div style="font-size:11px;color:var(--muted)">Financial Director</div></div>
      </div>
    </div>
    <hr class="dv">
    <div class="sh">Bill of Materials</div>
    <p style="font-size:11px;color:var(--muted);margin-bottom:10px">Check stock codes, descriptions and quantities. Procurement will add pricing.</p>

    <!-- PASTE FROM EXCEL -->
