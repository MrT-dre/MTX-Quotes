const DLAB=[{code:'MLAB0087',name:'Kitting Fee',uom:'Per Line Item',rate:0,qty:13},{code:'MLAB0002',name:'SMD Placements',uom:'Placements',rate:1.0,qty:17},{code:'MLAB0020',name:'SMD Setup',uom:'Time (Min)',rate:1500,qty:0},{code:'MLAB0020B',name:'SMD Solder Paste',uom:'Each',rate:14.75,qty:0.167},{code:'MLAB0003',name:'AOI',uom:'Panels',rate:26.82,qty:0.167},{code:'MLAB0071',name:'Wave/Hand 1-4 pins',uom:'Placements',rate:0.46,qty:0},{code:'MLAB0072',name:'Wave/Hand >4 pins',uom:'Placements',rate:0.92,qty:9},{code:'MLAB0007',name:'Programming',uom:'Time (Min)',rate:0.60,qty:0},{code:'MLAB0008',name:'Testing',uom:'Time (Min)',rate:1.69,qty:0},{code:'MLAB0009',name:'Assembly',uom:'Time (Min)',rate:1.97,qty:0},{code:'MLAB0010',name:'Conformal Coating',uom:'Panels',rate:29.21,qty:0},{code:'MLAB0011',name:'Washing',uom:'Panels',rate:5.43,qty:0},{code:'MLAB0034',name:'Packing',uom:'Each',rate:1.61,qty:2}];
