async function runBOMVerification(){
  if(!S.bomVerifyRows.length){toast('⚠️','No BOM','Go back and add BOM rows first.');return;}
  const btn=document.getElementById('bv-run-btn');
  btn.disabled=true;btn.textContent='🔄 Checking...';
  document.getElementById('bv-prog').style.display='flex';
  document.getElementById('bv-bar').style.width='0%';
  document.getElementById('bv-prog-text').textContent='0 / '+S.bomVerifyRows.length;
  // Reset statuses
  S.bomVerifyRows.forEach(r=>{r.status='pending';r.foundDesc=null;r.foundSupplier=null;r.foundCode=null;r.manualOverride=null;});
  renderBOMVerifyTable();
  let done=0;
  const total=S.bomVerifyRows.length;
  const lookups=S.bomVerifyRows.map((row,i)=>lookupComponent(row,i).then(()=>{
    done++;
    const pct=Math.round(done/total*100);
    document.getElementById('bv-bar').style.width=pct+'%';
    document.getElementById('bv-prog-text').textContent=done+' / '+total;
    renderBOMVerifyTable();
  }).catch(()=>{done++;renderBOMVerifyTable();}));
  await Promise.allSettled(lookups);
  btn.disabled=false;btn.textContent='🔍 Re-run Verification';
  toast('✅','Verification Complete','Review results — mark any pending rows manually.');
}

async function lookupComponent(row,idx){
  const code=row.code.trim();
  // Try LCSC public API
  try{
    const url='https://wmsc.lcsc.com/wmsc/product/detail?productCode='+encodeURIComponent(code);
    const proxy='https://api.allorigins.win/get?url='+encodeURIComponent(url);
    const ctrl=new AbortController();
    const tid=setTimeout(()=>ctrl.abort(),9000);
    const resp=await fetch(proxy,{signal:ctrl.signal});
    clearTimeout(tid);
    const data=await resp.json();
    const parsed=JSON.parse(data.contents||'{}');
    const res=parsed.result||parsed.data||parsed;
    const foundCode=(res.productCode||res.productModel||'').toString().trim();
    const foundDesc=(res.productDescription||res.productIntroEn||res.description||'').toString().trim();
    const foundSup='LCSC';
    if(foundCode||foundDesc){
      row.foundCode=foundCode;
      row.foundDesc=foundDesc.length>80?foundDesc.slice(0,80)+'…':foundDesc;
      row.foundSupplier=foundSup;
      // Check match: code match AND description keyword overlap
      const codeMatch=foundCode.toLowerCase()===code.toLowerCase();
      const descWords=row.desc.toLowerCase().split(/\W+/).filter(w=>w.length>2);
      const foundWords=foundDesc.toLowerCase();
      const descScore=descWords.length?descWords.filter(w=>foundWords.includes(w)).length/descWords.length:0;
      row.status=(codeMatch||descScore>=0.4)?'match':'mismatch';
      return;
    }
  }catch(e){}
  // Fallback: mark as pending (manual review needed)
  row.status='pending';
}

