function parsePasteData(raw){
  const rows=[];
  const lines=raw.split('\n');
  for(let line of lines){
    line=line.trim();
    if(!line) continue;
    // Split on tabs (Excel default) or multiple spaces
    const cols=line.split(/\t|  +/);
    if(cols.length<2) continue; // need at least code + desc
    const code=(cols[0]||'').trim();
    const desc=(cols[1]||'').trim();
    const qtyRaw=(cols[2]||'1').trim().replace(/[^0-9.]/g,'');
    const qty=parseFloat(qtyRaw)||1;
    const supplier=(cols[3]||'').trim();
    if(!code && !desc) continue;
    rows.push({code,desc,qty,supplier});
  }
  return rows;
}

function livePreviewPaste(raw){
  const prev=document.getElementById('paste-preview');
  if(!raw.trim()){prev.style.display='none';return;}
  const rows=parsePasteData(raw);
  if(!rows.length){prev.style.display='none';return;}
  prev.style.display='block';
  prev.innerHTML='<div style="font-weight:600;margin-bottom:6px;color:var(--accent2)">Preview — '+rows.length+' row'+(rows.length>1?'s':'')+' detected:</div>'+
