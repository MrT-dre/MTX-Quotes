function buildLab(){document.getElementById('lab-body').innerHTML=S.labRows.map((r,i)=>`<tr><td style="color:var(--muted);font-size:10px">${r.code}</td><td>${r.name}</td><td style="color:var(--muted);font-size:11px">${r.uom}</td><td><input type="number" value="${r.rate}" min="0" step="0.01" oninput="S.labRows[${i}].rate=parseFloat(this.value||0);calcLab()" style="width:80px"></td><td><input type="number" value="${r.qty}" min="0" step="0.001" oninput="S.labRows[${i}].qty=parseFloat(this.value||0);calcLab()" style="width:80px"></td><td id="lc${i}" class="ta">R 0.00</td></tr>`).join('');calcLab();}
function calcLab(){let sub=0;S.labRows.forEach((r,i)=>{r.cost=(r.rate||0)*(r.qty||0);sub+=r.cost;const el=document.getElementById('lc'+i);if(el)el.textContent=fR(r.cost);});const kit=parseFloat(document.getElementById('m-kit').value)||6,dp=(parseFloat(document.getElementById('m-dsl').value)||2.5)/100,base=sub+kit,dsl=base*dp;S.labTot=base+dsl;S.kit=kit;S.diesel=dsl;document.getElementById('lab-sub').textContent=fR(sub);document.getElementById('ms-l').textContent=fR(sub);document.getElementById('ms-k').textContent=fR(kit);document.getElementById('ms-d').textContent=fR(dsl);document.getElementById('ms-t').textContent=fR(S.labTot);}
function submitMfg(){calcLab();document.getElementById('a-comp').textContent=fR(S.compTot/S.qty);document.getElementById('a-src').textContent=fR(S.srcTot/S.qty);document.getElementById('a-moq').textContent=fR(S.moqTot/S.qty);const ls=S.labRows.reduce((s,r)=>s+(r.cost||0),0);document.getElementById('a-lab').textContent=fR(ls);document.getElementById('a-kit').textContent=fR(S.kit);document.getElementById('a-dsl').textContent=fR(S.diesel);document.getElementById('appr-who').textContent='Awaiting approval from: '+S.approver;document.getElementById('appr-sub').textContent=S.approver==='Chris'?' — Managing Director':' — Financial Director';calcApproval();done(6);showP(7);
  const apprEmail=S.approver==='Chris'?EMAILS.Chris:EMAILS.Adam;
  sendEmail(apprEmail,'[Microtronix Quotes] Quote Approval Required — '+S.rfqId+' ('+S.cust+')','Hi '+S.approver+',\n\nA quote is ready for your approval:\n\nRFQ ID: '+S.rfqId+'\nCustomer: '+S.cust+'\nPCB: '+S.pcb+'\nQuantity: '+S.qty+' boards\nKAM: '+S.kam+'\nEst. Quote (pre-markup): '+fR((S.compTot+S.srcTot+S.moqTot)/S.qty+S.labTot)+' per board\n\nPlease open the Quote Workflow System, review all costs, set the markup and approve or request a revision.\n\nThanks,\nMicrotronix Quote System');
  markEmailSent('submitmfg');
  setTimeout(()=>sendEmail(apprEmail,'[Microtronix Quotes] Approval Required — '+S.rfqId+' ('+S.cust+')',apprEmail),400);
  toast('📧','Sent to '+S.approver,'Approval request — email opening');}

// S6
function buildApproval(){
  document.getElementById('a-comp').textContent=fR(S.compTot/S.qty);
  document.getElementById('a-src').textContent=fR(S.srcTot/S.qty);
  document.getElementById('a-moq').textContent=fR(S.moqTot/S.qty);
  const ls=S.labRows.reduce((s,r)=>s+(r.cost||0),0);
  document.getElementById('a-lab').textContent=fR(ls);
  document.getElementById('a-kit').textContent=fR(S.kit||6);
  document.getElementById('a-dsl').textContent=fR(S.diesel||0);
  document.getElementById('appr-who').textContent='Awaiting approval from: '+(S.approver||'—');
  document.getElementById('appr-sub').textContent=S.approver==='Chris'?' — Managing Director':' — Financial Director';
  calcApproval();
}
function calcApproval(){const cp=S.compTot/S.qty,sp=S.srcTot/S.qty,mp=S.moqTot/S.qty,mt=cp+sp+mp+S.labTot,mk=(parseFloat(document.getElementById('a-mk').value)||40)/100,co=(parseFloat(document.getElementById('a-com').value)||0)/100,mkR=mt*mk,coR=mt*co,q=mt+mkR-coR;S.markup=mk*100;S.comm=co*100;S.qpb=q;S.otot=q*S.qty;document.getElementById('a-mt').textContent=fR(mt);document.getElementById('a-mr').textContent=fR(mkR);document.getElementById('a-cr').textContent=fR(coR);document.getElementById('a-q').textContent=fR(q);document.getElementById('a-tot').textContent=fR(S.otot);}
function approveQuote(){calcApproval();buildSAP();done(7);showP(8);syncRFQ();renderDash();
  const apprBody='Hi '+S.kam+',\n\nGreat news! Your quote has been approved by '+S.approver+'.\n\nRFQ ID: '+S.rfqId+'\nCustomer: '+S.cust+'\nApproved Quote: '+fR(S.qpb)+' per board\nTotal: '+fR(S.otot)+'\nApproved by: '+S.approver+'\n\nThanks,\nMicrotronix Quote System';
  markEmailSent('approve');
  setTimeout(()=>sendEmail(EMAILS[S.kam],'[Microtronix Quotes] APPROVED — '+S.rfqId+' ('+S.cust+')',apprBody),400);
  toast('✅','Quote Approved!','Notification to '+S.kam+' — email opening');}

function showRejectPanel(){document.getElementById('reject-panel').style.display='block';document.getElementById('reject-panel').scrollIntoView({behavior:'smooth',block:'nearest'});}
function hideRejectPanel(){document.getElementById('reject-panel').style.display='none';}
function updateRejTarget(){
  const val=document.getElementById('rej-to').value;
  const info=document.getElementById('rej-target-info');
  const emailDisplay=document.getElementById('rej-email-display');
  if(!val){info.style.display='none';return;}
  let emailStr='';
  if(val==='Manufacturing')emailStr='hamesh@microtronix.co.za';
  else if(val==='Procurement')emailStr='angelas@microtronix.co.za, lerato@microtronix.co.za';
  else if(val==='KAM')emailStr=EMAILS[S.kam]||S.kam;
  emailDisplay.textContent=emailStr;
  info.style.display='block';
}
function confirmReject(){
  const sendTo=document.getElementById('rej-to').value;
  const notes=document.getElementById('rej-notes').value.trim();
  const priority=document.getElementById('rej-priority').value;
  if(!sendTo){toast('⚠️','Select Recipient','Please choose who to send the revision to.');return;}
  if(!notes){toast('⚠️','Notes Required','Please describe what changes are needed.');return;}
  let toEmail='',toName='',stageMsg='';
  if(sendTo==='Manufacturing'){toEmail=EMAILS.Manufacturing;toName='Hamesh';stageMsg='Please review and update the labour costs in the Quote Workflow System, then resubmit for approval.';}
  else if(sendTo==='Procurement'){toEmail=EMAILS.Procurement;toName='Angela / Lerato';stageMsg='Please review and update the component pricing in the Quote Workflow System, then resubmit to Manufacturing.';}
  else if(sendTo==='KAM'){toEmail=EMAILS[S.kam];toName=S.kam;stageMsg='Please review the order details and BOM in the Quote Workflow System, make the necessary changes, then resubmit to Procurement.';}
  const subject='['+priority+'] [Microtronix Quotes] Revision Required — '+S.rfqId+' ('+S.cust+')';
  const body='Hi '+toName+',\n\nA revision has been requested on the following quote by '+S.approver+':\n\nRFQ ID: '+S.rfqId+'\nCustomer: '+S.cust+'\nPCB: '+S.pcb+'\nQuantity: '+S.qty+' boards\nKAM: '+S.kam+'\nPriority: '+priority+'\n\nCHANGES REQUIRED:\n'+notes+'\n\n'+stageMsg+'\n\nThanks,\nMicrotronix Quote System';
  sendEmail(toEmail,subject,body);
  hideRejectPanel();
  // Navigate back to correct stage
  if(sendTo==='Manufacturing')showP(6);
  else if(sendTo==='Procurement')showP(5);
  else showP(3);
  toast('📧','Revision Request Sent','Email opened to '+toName+' — '+priority+' priority');
}

// S7
function buildSAP(){const td=new Date().toLocaleDateString('en-ZA');['sap-kam','sap-rfq','sap-appr','sap-appr2','sap-dt'].forEach((id,j)=>document.getElementById(id).textContent=[S.kam,S.rfqId,S.approver,S.approver,td][j]);['sap-cust','sap-pcb','sap-qty'].forEach((id,j)=>document.getElementById(id).textContent=[S.cust,S.pcb,S.qty][j]);document.getElementById('sap-up').textContent=fR(S.qpb);document.getElementById('sap-ov').textContent=fR(S.otot);document.getElementById('sap-comp').textContent=fR(S.compTot/S.qty);document.getElementById('sap-src').textContent=fR(S.srcTot/S.qty);document.getElementById('sap-moq').textContent=fR(S.moqTot/S.qty);document.getElementById('sap-lab').textContent=fR(S.labTot);document.getElementById('sap-dsl').textContent=fR(S.diesel);const mk=(S.compTot/S.qty+S.srcTot/S.qty+S.moqTot/S.qty+S.labTot)*(S.markup/100);document.getElementById('sap-mk').textContent=fR(mk);document.getElementById('sap-gm').textContent=(mk/S.qpb*100).toFixed(1)+'%';document.getElementById('sap-cls').textContent=document.getElementById('k-cls').value;document.getElementById('sap-smd').textContent=document.getElementById('k-smd').value;document.getElementById('sap-conv').textContent=document.getElementById('k-conv').value;document.getElementById('sap-bom').textContent=document.getElementById('k-bom').value;document.getElementById('sap-bpp').textContent=S.bpp;document.getElementById('sap-np').textContent=Math.ceil(S.qty/S.bpp);const svcs=[['svc-cc','Conformal Coating'],['svc-wash','Washing'],['svc-prog','Programming'],['svc-test','Testing'],['svc-assy','Assembly'],['svc-pack','Packing'],['svc-wave','Wave Solder'],['svc-aoi','AOI']].filter(([id])=>document.getElementById(id).checked).map(([,n])=>n);document.getElementById('sap-svcs').textContent=svcs.length?svcs.join(', '):'Standard only';const d8=new Date().toISOString().split('T')[0].replace(/-/g,'');document.getElementById('sap-fp').textContent=S.cust;document.getElementById('sap-fn').textContent=S.rfqId+'_'+S.pcb+'_'+d8+'.xlsx';document.getElementById('sap-bom-body').innerHTML=S.procRows.map(r=>`<tr><td style="font-size:11px;color:var(--label)">${esc(r.code)}</td><td>${esc(r.desc)}</td><td style="color:var(--muted)">${Math.round(r.totalQty/S.qty)}</td><td>${r.totalQty}</td><td>${r.unitPrice?fR(r.unitPrice):'—'}</td><td>${r.lineTotal?fR(r.lineTotal):'—'}</td><td style="color:var(--accent)">${r.srcFee?fR(r.srcFee):'—'}</td></tr>`).join('');}
function exportCSV(){const rows=[['RFQ ID',S.rfqId],['Customer',S.cust],['PCB',S.pcb],['Quantity',S.qty],['KAM',S.kam],['Approver',S.approver],['Unit Price (R)',S.qpb.toFixed(2)],['Total Order Value (R)',S.otot.toFixed(2)],['Component Cost/Board',(S.compTot/S.qty).toFixed(2)],['Source Fee/Board',(S.srcTot/S.qty).toFixed(2)],['MOQ/Board',(S.moqTot/S.qty).toFixed(2)],['Labour/Board',S.labTot.toFixed(2)],[],['Stock Code','Description','Total Qty','Unit Price','Line Total','Source Fee'],...S.procRows.map(r=>[r.code,r.desc,r.totalQty,r.unitPrice?.toFixed(2)||0,r.lineTotal?.toFixed(2)||0,r.srcFee?.toFixed(2)||0])];const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([rows.map(r=>r.join(',')).join('\n')],{type:'text/csv'}));a.download=S.rfqId+'_SAP_Quote.csv';a.click();toast('📊','CSV Downloaded','SAP import file ready.');}
function fb(m){sendEmail('chris.schoeman@microtronix.co.za','[Microtronix Quote System] Feedback','Hi Chris,\n\nFeedback on the Quote Workflow System:\n\n'+m+'\n\nFrom: '+S.role+'\nDate: '+new Date().toLocaleDateString('en-ZA'));toast('📧','Email Opened','Feedback email to Chris opened');}

// INSTALL / PWA
let _installPrompt=null;
window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault();_installPrompt=e;
  const b=document.getElementById('install-banner');
  b.classList.add('show');
  // Hide iOS-specific button on Android (prompt handles it natively)
  document.querySelector('.install-ios').style.display='none';
  // Show header button too
  document.getElementById('install-header-btn').style.display='inline-flex';
});
window.addEventListener('appinstalled',()=>{
  document.getElementById('install-banner').classList.remove('show');
  document.getElementById('install-header-btn').style.display='none';
  toast('🎉','App Installed!','MTX Quotes is now on your home screen');
});
// iOS detection — show guide button instead
const isIOS=/iphone|ipad|ipod/i.test(navigator.userAgent)&&!window.MSStream;
const isInStandalone=window.navigator.standalone===true||window.matchMedia('(display-mode: standalone)').matches;
if(isIOS&&!isInStandalone){
  const b=document.getElementById('install-banner');
  b.classList.add('show');
  document.getElementById('install-btn').style.display='none';
  document.querySelector('.install-ios').style.display='flex';
  // Show header button for iOS too (opens guide)
  document.getElementById('install-header-btn').style.display='inline-flex';
}
// If already installed (standalone), keep button hidden
if(isInStandalone){
  document.getElementById('install-header-btn').style.display='none';
}
function headerInstall(){
  // 1. Native prompt available (Chrome/Edge on Android or desktop)
  if(_installPrompt){ installApp(); return; }
  // 2. Already installed
  if(isInStandalone){
    toast('✅','Already Installed','MTX Quotes is already on your device.');
    return;
  }
  // 3. iOS Safari - show guide
  if(isIOS){ showIOSGuide(); return; }
  // 4. Running from local file (file://)
  if(location.protocol==='file:'){
    document.getElementById('install-help').style.display='flex';
    return;
  }
  // 5. Desktop Chrome/Edge - install icon in address bar
  const ua=navigator.userAgent;
  const isChrome=/Chrome|Chromium|Edg/.test(ua)&&!/OPR|Opera/.test(ua);
  if(isChrome){
    toast('⬇️','Install via Address Bar','Look for the install icon (⊕ or 💻) on the right side of your browser\'s address bar, or open the ⋮ menu → "Install MTX Quotes".');
    return;
  }
  // 6. Other browsers
  toast('ℹ️','How to Install','Open your browser menu and look for "Install App" or "Add to Home Screen". This feature works best in Chrome, Edge, or Safari.');
}
function installApp(){if(_installPrompt){_installPrompt.prompt();_installPrompt.userChoice.then(r=>{if(r.outcome==='accepted'){document.getElementById('install-banner').classList.remove('show');document.getElementById('install-header-btn').style.display='none';toast('🎉','Installing!','MTX Quotes is being added to your home screen');}});}}
function dismissInstall(){document.getElementById('install-banner').classList.remove('show');localStorage.setItem('install-dismissed','1');}
function showIOSGuide(){document.getElementById('ios-guide').style.display='flex';}
// Don't re-show banner if dismissed (but keep header button available)
if(localStorage.getItem('install-dismissed')){document.getElementById('install-banner').classList.remove('show');}

</script>
