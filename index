    const searchLinks=`<div class="search-links">
      <a class="search-link" href="https://www.lcsc.com/search?q=${encodeURIComponent(r.code)}" target="_blank">LCSC</a>
      <a class="search-link" href="https://www.mouser.com/Search/Refine?Keyword=${encodeURIComponent(r.code)}" target="_blank">Mouser</a>
      <a class="search-link" href="https://www.digikey.com/en/products/result?keywords=${encodeURIComponent(r.code)}" target="_blank">DigiKey</a>
    </div>`;
    const manualBtns=`<div style="display:flex;gap:4px;margin-top:4px">
      <button onclick="bomVerifyManual(${i},'manual-ok')" style="font-size:10px;padding:2px 7px;background:rgba(0,229,160,.12);color:var(--accent);border:1px solid rgba(0,229,160,.25);border-radius:5px;cursor:pointer">✓ Mark OK</button>
      <button onclick="bomVerifyManual(${i},'manual-fail')" style="font-size:10px;padding:2px 7px;background:rgba(255,107,53,.1);color:var(--accent3);border:1px solid rgba(255,107,53,.25);border-radius:5px;cursor:pointer">✗ Flag</button>
    </div>`;
    return `<tr class="${rowCls}"><td>${badge}</td><td style="font-size:11px;color:var(--accent2);font-weight:500">${esc(r.code)}</td><td style="font-size:11px">${esc(r.desc)}</td><td>${foundDesc}</td><td>${foundSup}</td><td>${searchLinks}${manualBtns}</td></tr>`;
  }).join('');
  // Update summary counts
  const match=rows.filter(r=>(r.manualOverride||r.status)==='match'||(r.manualOverride||r.status)==='manual-ok').length;
  const mis=rows.filter(r=>(r.manualOverride||r.status)==='mismatch'||(r.manualOverride||r.status)==='manual-fail').length;
  const pend=rows.filter(r=>!r.manualOverride&&r.status==='pending').length;
  document.getElementById('bv-cnt-match').textContent=match;
  document.getElementById('bv-cnt-mismatch').textContent=mis;
  document.getElementById('bv-cnt-pending').textContent=pend;
